generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  workspaces    WorkspaceMember[]
  transactions  Transaction[]     @relation("PaidBy")
  splits        TransactionSplit[]
  
  @@map("users")
}

model Workspace {
  id          String    @id @default(cuid())
  name        String
  type        WorkspaceType @default(PERSONAL)
  currency    String    @default("BRL")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  members     WorkspaceMember[]
  transactions Transaction[]
  categories  Category[]
  budgets     Budget[]
  
  @@map("workspaces")
}

enum WorkspaceType {
  PERSONAL
  SHARED
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime  @default(now())
  
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  splits    TransactionSplit[]
  
  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

model Category {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  icon        String
  color       String
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  
  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
  
  @@map("categories")
}

model Transaction {
  id          String            @id @default(cuid())
  workspaceId String
  amount      Decimal           @db.Decimal(12, 2)
  type        TransactionType
  categoryId  String?
  description String
  date        DateTime
  paidById    String
  imageUrl    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category  Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  paidBy    User               @relation("PaidBy", fields: [paidById], references: [id], onDelete: Cascade)
  splits    TransactionSplit[]
  
  @@index([workspaceId, date])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

model TransactionSplit {
  id            String      @id @default(cuid())
  transactionId String
  userId        String
  shareAmount   Decimal     @db.Decimal(12, 2)
  status        SplitStatus @default(PENDING)
  
  transaction Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  member      WorkspaceMember @relation(fields: [userId, workspaceId], references: [userId, workspaceId])
  workspaceId String
  
  @@unique([transactionId, userId])
  @@map("transaction_splits")
}

enum SplitStatus {
  PENDING
  SETTLED
}

model Budget {
  id           String    @id @default(cuid())
  workspaceId  String
  categoryId   String
  limitAmount  Decimal   @db.Decimal(12, 2)
  period       BudgetPeriod @default(MONTHLY)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  @@unique([workspaceId, categoryId, period])
  @@map("budgets")
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}
